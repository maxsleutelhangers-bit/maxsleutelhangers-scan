{
  "version": 2,
  "public": true,
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/scan", "destination": "/scan.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 10 }
  }
}
